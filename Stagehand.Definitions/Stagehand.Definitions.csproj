<Project Sdk="Microsoft.NET.Sdk">
    <Import Project="../Common.targets" />

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- NuGet package properties -->
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <Authors>UniversalConquistador</Authors>
        <Title>Stage Definition Format</Title>
        <Description>Defines the file format of Stage definitions.</Description>
        <PackageProjectUrl>https://github.com/universalconquistador/Stagehand</PackageProjectUrl>
        <Copyright>Copyright (c) UniversalConquistador</Copyright>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <RepositoryType>git</RepositoryType>
        <RepositoryUrl>https://github.com/universalconquistador/Stagehand.git</RepositoryUrl>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <PackageTags>FFXIV;Dalamud;Stagehand</PackageTags>
        <GenerateDocumentationFile>True</GenerateDocumentationFile>
        <EmbedAllSources>True</EmbedAllSources>
        <DebugType>Embedded</DebugType>
        <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
        <Platforms>AnyCPU;x64</Platforms>
    </PropertyGroup>

    <ItemGroup>
        <None Include="README.md">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
        <None Include="../Stagehand Logo 2x.png">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
    </ItemGroup>
</Project>
